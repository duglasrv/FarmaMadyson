JWT_REFRESH_EXPIRATION="7d"

# 2FA Email (Admin)
EMAILJS_SERVICE_ID="service_xxxxx"
EMAILJS_TEMPLATE_ID_2FA="template_xxxxx"
EMAILJS_PUBLIC_KEY="xxxxx"
SENDGRID_API_KEY="SG.xxxxx"
